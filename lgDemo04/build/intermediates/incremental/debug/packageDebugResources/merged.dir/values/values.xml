<?xml version="1.0" encoding="utf-8"?>
<resources>
    <color name="btnbg">#232323</color>
    <color name="btntxt">#FAF7F7</color>
    <color name="colorAccent">#03DAC5</color>
    <color name="colorPrimary">#6200EE</color>
    <color name="colorPrimaryDark">#3700B3</color>
    <color name="text">#f37301</color>
    <string name="MYMU">我的音乐盒</string>
    <string name="app_name">lgDemo04</string>
    <string name="btnLogin">登录</string>
    <string name="btnReg">注册</string>
    <string name="tvPwd">密码：</string>
    <string name="tvUid">账号：</string>
    <style name="AppTheme" parent="Theme.AppCompat.Light.DarkActionBar">
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>
        <item name="android:windowNoTitle">true</item>
    </style>
    <style name="button">
        <item name="android:textSize">20sp</item>
        <item name="android:textColor">@color/btntxt</item>
        <item name="android:background">@color/btnbg</item>
        <item name="android:textStyle">bold</item>
    </style>
    <style name="edit">
        <item name="android:textSize">18sp</item>
        <item name="android:textColor">@color/colorAccent</item>
        <item name="android:background">@android:drawable/editbox_background</item>
        <item name="android:textStyle">bold</item>
    </style>
    <style name="text">
        <item name="android:textSize">18sp</item>
        <item name="android:textColor">@color/text</item>
        <item name="android:textStyle">bold</item>
    </style>
    <style name="title">
        <item name="android:textSize">32sp</item>
        <item name="android:textColor">@color/text</item>
        <item name="android:textStyle">bold</item>
    </style>
